{
  "name": "@love-rox/tcy-react",
  "version": "0.3.0",
  "description": "React <Tcy> component for Japanese tate-chu-yoko (縦中横) auto-wrap",
  "keywords": [
    "japanese",
    "react",
    "tate-chu-yoko",
    "vertical-writing",
    "縦中横"
  ],
  "homepage": "https://github.com/Love-Rox/tate-chu-yoko#readme",
  "bugs": {
    "url": "https://github.com/Love-Rox/tate-chu-yoko/issues"
  },
  "license": "MIT",
  "author": "SASAGAWA Kiyoshi <dev@love-rox.cc>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Love-Rox/tate-chu-yoko.git",
    "directory": "packages/react"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@love-rox/tcy-core": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "peerDependencies": {
    "react": ">=17"
  }
}
